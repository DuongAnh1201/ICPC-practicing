{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build active file",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++17",
                "-g",
                "-Wall",
                "-Wextra",
                "-o", "${fileDirname}/${fileBasenameNoExtension}",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build and run active file",
            "type": "shell",
            "command": "clang++",
            "args": [
                "-std=c++17",
                "-O2",
                "-o", "${fileDirname}/${fileBasenameNoExtension}",
                "${file}"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"],
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
